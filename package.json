{
  "name": "messenger",
  "version": "1.1.1",
  "description": "Messenger desktop app for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "release": "./scripts/release.sh",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "release:rebuild": "./scripts/release.sh --rebuild"
  },
  "keywords": [
    "messenger",
    "facebook",
    "chat"
  ],
  "author": "Vinh Tran (VinhTNK)",
  "license": "ISC",
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.vinhtnk.messenger",
    "productName": "Messenger",
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.social-networking",
      "target": [
        "dmg",
        "zip"
      ],
      "notarize": true
    },
    "publish": {
      "provider": "github",
      "owner": "vinhtnk",
      "repo": "messenger",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2"
  }
}
